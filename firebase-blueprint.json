{
  "entities": {
    "Review": {
      "title": "Review",
      "description": "A review or testimonial submitted by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "rating": { "type": "number" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["Physical Wellness", "Mental Clarity", "Spiritual Healing", "Kids Yoga", "Dance Therapy", "Tarot Reading", "Chair Yoga"] },
        "role": { "type": "string" },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lang": { "type": "string", "enum": ["EN", "DE"] }
      },
      "required": ["name", "rating", "content", "category", "createdAt", "lang"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "An article or blog post published by trainers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lang": { "type": "string", "enum": ["EN", "DE"] }
      },
      "required": ["slug", "title", "content", "createdAt", "lang"]
    }
  },
  "firestore": {
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of user-submitted reviews."
    },
    "/blogs/{blogId}": {
      "schema": "BlogPost",
      "description": "Collection of blog posts and articles."
    }
  }
}
