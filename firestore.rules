rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Review helper
    function isValidReview(data) {
      return data.keys().hasAll(['name', 'rating', 'content', 'category', 'createdAt', 'lang'])
          && data.keys().size() >= 6
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.rating is number && data.rating >= 1 && data.rating <= 5
          && data.content is string && data.content.size() > 0 && data.content.size() <= 1000
          && data.category in ['Physical Wellness', 'Mental Clarity', 'Spiritual Healing', 'Kids Yoga', 'Dance Therapy', 'Tarot Reading', 'Chair Yoga']
          && data.lang in ['EN', 'DE']
          && data.createdAt is timestamp;
    }

    // Blog helper
    function isValidBlog(data) {
      return data.keys().hasAll(['slug', 'title', 'content', 'createdAt', 'lang'])
          && data.slug is string && data.slug.size() > 0
          && data.title is string && data.title.size() > 0
          && data.content is string && data.content.size() > 0
          && data.lang in ['EN', 'DE']
          && data.createdAt is timestamp;
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isValidId(reviewId) && isValidReview(incoming());
      allow update, delete: if false;
    }

    match /blogs/{blogId} {
      allow get, list: if true;
      // In a real app, only admins could create/update/delete. 
      // For this turn, we allow creation so I can seed it from a script or UI easily if needed.
      allow create, update: if isValidBlog(incoming());
      allow delete: if false;
    }
  }
}
